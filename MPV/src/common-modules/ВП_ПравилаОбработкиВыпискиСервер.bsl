#Область ПрограммныйИнтерфейс

// Применяет пользовательские правила перед штатным созданием банковских документов.
//
// Параметры:
//  Выписка - Структура - см. ЗагрузкаВыпискиПоБанковскомуСчету.НовыйВыпискаПоБанковскомуСчету()
//  РаспознаннаяВыписка - Структура - результат штатного распознавания выписки
//  Настройки - Структура - настройки загрузки выписки
//  Отбор - Массив, Неопределено - идентификаторы операций, которые нужно обработать
//
// Возвращаемое значение:
//  Структура - счетчики применения правил.
//
Функция ПрименитьПравилаПередСозданиемДокументов(Выписка, РаспознаннаяВыписка, Настройки, Отбор = Неопределено) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Рассмотрено", 0);
	Результат.Вставить("Применено", 0);
	Результат.Вставить("НеНайденСчет", 0);
	Результат.Вставить("Пропущено", 0);
	
	Если Выписка = Неопределено
		Или РаспознаннаяВыписка = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Правила = АктивныеПравила();
	Если Правила.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	Для Каждого Операция Из Выписка.Операции Цикл
		
		Если Отбор <> Неопределено
			И Отбор.Найти(Операция.Идентификатор) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Результат.Рассмотрено = Результат.Рассмотрено + 1;
		
		Если Не ЭтоНоваяОперацияДляПравил(Операция, РаспознаннаяВыписка) Тогда
			Результат.Пропущено = Результат.Пропущено + 1;
			Продолжить;
		КонецЕсли;
		
		РаспознаннаяОперация = РаспознаннаяВыписка.Операции.Найти(Операция.Идентификатор, "Идентификатор");
		ХозяйственнаяОперация = РаспознаннаяОперация.ХозяйственнаяОперация;
		
		Правило = ПервоеПодходящееПравило(Правила, Выписка, РаспознаннаяВыписка, Операция, ХозяйственнаяОперация);
		Если Правило = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		КоличествоЗаполненныхРеквизитов = ПрименитьДействияПравила(
			Правило,
			Операция,
			ХозяйственнаяОперация);
		
		Если Не ПравилоЗаполняетСчетНаОплату(Правило) Тогда
			Если КоличествоЗаполненныхРеквизитов > 0 Тогда
				ОчиститьСохраненноеАвтозаполнение(ХозяйственнаяОперация);
				Результат.Применено = Результат.Применено + 1;
				ЗаписатьЖурналПрименения(
					Правило,
					Выписка,
					РаспознаннаяВыписка,
					Операция,
					ХозяйственнаяОперация,
					Документы.СчетНаОплатуПокупателю.ПустаяСсылка(),
					"Применено",
					СтрШаблон("Заполнено реквизитов: %1.", КоличествоЗаполненныхРеквизитов));
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		
		СуществующийСчет = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
			ХозяйственнаяОперация,
			"СчетНаОплату",
			Документы.СчетНаОплатуПокупателю.ПустаяСсылка());
		
		Если ЗначениеЗаполнено(СуществующийСчет)
			И Правило.РежимЗаполненияСчета = Перечисления.ВП_РежимыЗаполненияСчетаНаОплату.ТолькоЕслиПусто Тогда
			Если КоличествоЗаполненныхРеквизитов > 0 Тогда
				ОчиститьСохраненноеАвтозаполнение(ХозяйственнаяОперация);
				Результат.Применено = Результат.Применено + 1;
			КонецЕсли;
			ЗаписатьЖурналПрименения(
				Правило,
				Выписка,
				РаспознаннаяВыписка,
				Операция,
				ХозяйственнаяОперация,
				СуществующийСчет,
				?(КоличествоЗаполненныхРеквизитов > 0, "Применено", "Пропущено"),
				?(КоличествоЗаполненныхРеквизитов > 0,
					СтрШаблон("Счет на оплату уже заполнен типовой логикой. Заполнено реквизитов: %1.", КоличествоЗаполненныхРеквизитов),
					"Счет на оплату уже заполнен типовой логикой."));
			Продолжить;
		КонецЕсли;
		
		РезультатПоиска = СчетНаОплатуПоПравилу(Правило, Выписка, РаспознаннаяВыписка, Операция, ХозяйственнаяОперация);
		Если Не РезультатПоиска.Успешно Тогда
			Результат.НеНайденСчет = Результат.НеНайденСчет + 1;
			Если КоличествоЗаполненныхРеквизитов > 0 Тогда
				ОчиститьСохраненноеАвтозаполнение(ХозяйственнаяОперация);
				Результат.Применено = Результат.Применено + 1;
			КонецЕсли;
			ЗаписатьЖурналПрименения(
				Правило,
				Выписка,
				РаспознаннаяВыписка,
				Операция,
				ХозяйственнаяОперация,
				Документы.СчетНаОплатуПокупателю.ПустаяСсылка(),
				?(КоличествоЗаполненныхРеквизитов > 0, "Применено частично", "Не найден счет"),
				?(КоличествоЗаполненныхРеквизитов > 0,
					СтрШаблон("%1 Заполнено реквизитов: %2.", РезультатПоиска.Сообщение, КоличествоЗаполненныхРеквизитов),
					РезультатПоиска.Сообщение));
			Продолжить;
		КонецЕсли;
		
		ХозяйственнаяОперация.Вставить("СчетНаОплату", РезультатПоиска.Счет);
		ОчиститьСохраненноеАвтозаполнение(ХозяйственнаяОперация);
		
		Результат.Применено = Результат.Применено + 1;
		ЗаписатьЖурналПрименения(
			Правило,
			Выписка,
			РаспознаннаяВыписка,
			Операция,
			ХозяйственнаяОперация,
			РезультатПоиска.Счет,
			"Применено",
			?(КоличествоЗаполненныхРеквизитов > 0,
				СтрШаблон("%1 Заполнено реквизитов: %2.", РезультатПоиска.Сообщение, КоличествоЗаполненныхРеквизитов),
				РезультатПоиска.Сообщение));
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Повторно применяет реквизиты к уже созданным документам.
// Нужна как страховка для реквизитов, которые типовая логика не всегда переносит из ХозяйственнойОперации.
Функция ПрименитьПравилаПослеСозданияДокументов(
	Выписка,
	РаспознаннаяВыписка,
	Настройки,
	Отбор = Неопределено,
	РезультатыСозданияДокументов = Неопределено) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Рассмотрено", 0);
	Результат.Вставить("Изменено", 0);
	Результат.Вставить("Пропущено", 0);
	
	Если Выписка = Неопределено
		Или РаспознаннаяВыписка = Неопределено
		Или РезультатыСозданияДокументов = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Правила = АктивныеПравила();
	Если Правила.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	Для Каждого Операция Из Выписка.Операции Цикл
		
		Если Отбор <> Неопределено
			И Отбор.Найти(Операция.Идентификатор) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Результат.Рассмотрено = Результат.Рассмотрено + 1;
		
		РезультатСоздания = РезультатыСозданияДокументов[Операция.Идентификатор];
		Если РезультатСоздания = Неопределено
			Или Не ЗначениеЗаполнено(РезультатСоздания.Ссылка) Тогда
			Результат.Пропущено = Результат.Пропущено + 1;
			Продолжить;
		КонецЕсли;
		
		РаспознаннаяОперация = РаспознаннаяВыписка.Операции.Найти(Операция.Идентификатор, "Идентификатор");
		Если РаспознаннаяОперация = Неопределено
			Или РаспознаннаяОперация.ХозяйственнаяОперация = Неопределено Тогда
			Результат.Пропущено = Результат.Пропущено + 1;
			Продолжить;
		КонецЕсли;
		
		Правило = ПервоеПодходящееПравило(
			Правила,
			Выписка,
			РаспознаннаяВыписка,
			Операция,
			РаспознаннаяОперация.ХозяйственнаяОперация);
		Если Правило = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Попытка
			ДокументОбъект = РезультатСоздания.Ссылка.ПолучитьОбъект();
			Если ДокументОбъект = Неопределено Тогда
				Результат.Пропущено = Результат.Пропущено + 1;
				Продолжить;
			КонецЕсли;
			
			КоличествоЗаполненныхРеквизитов = ПрименитьДействияПравилаКДокументу(Правило, Операция, ДокументОбъект);
			Если КоличествоЗаполненныхРеквизитов = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			Если ДокументОбъект.Проведен Тогда
				ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
			Иначе
				ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
			КонецЕсли;
			
			Результат.Изменено = Результат.Изменено + 1;
			
		Исключение
			Результат.Пропущено = Результат.Пропущено + 1;
		КонецПопытки;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Возвращает активные правила в порядке применения.
Функция АктивныеПравила() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Правила.Ссылка КАК Ссылка,
	|	Правила.Наименование КАК Наименование,
	|	Правила.Приоритет КАК Приоритет,
	|	Правила.НаправлениеОперации КАК НаправлениеОперации,
	|	Правила.Организация КАК Организация,
	|	Правила.БанковскийСчетОрганизации КАК БанковскийСчетОрганизации,
	|	Правила.ВидОперацииДокумента КАК ВидОперацииДокумента,
	|	Правила.Контрагент КАК Контрагент,
	|	Правила.ИННПлательщика КАК ИННПлательщика,
	|	Правила.РежимПоискаСчета КАК РежимПоискаСчета,
	|	Правила.РежимЗаполненияСчета КАК РежимЗаполненияСчета,
	|	Правила.СчетНаОплатуПокупателю КАК СчетНаОплатуПокупателю,
	|	Правила.ВидОперацииПоступление КАК ВидОперацииПоступление,
	|	Правила.ВидОперацииСписание КАК ВидОперацииСписание,
	|	Правила.ЗаполняемыйКонтрагент КАК ЗаполняемыйКонтрагент,
	|	Правила.ЗаполняемыйДоговорКонтрагента КАК ЗаполняемыйДоговорКонтрагента,
	|	Правила.ЗаполняемыйБанковскийСчетКонтрагента КАК ЗаполняемыйБанковскийСчетКонтрагента,
	|	Правила.СтатьяДвиженияДенежныхСредств КАК СтатьяДвиженияДенежныхСредств,
	|	Правила.СчетДт КАК СчетДт,
	|	Правила.СчетКт КАК СчетКт,
	|	Правила.ПодразделениеДт КАК ПодразделениеДт,
	|	Правила.ПодразделениеКт КАК ПодразделениеКт,
	|	Правила.СтатьяПрочихДоходовИРасходов КАК СтатьяПрочихДоходовИРасходов
	|ИЗ
	|	Справочник.ВП_ПравилаОбработкиБанковскойВыписки КАК Правила
	|ГДЕ
	|	НЕ Правила.ПометкаУдаления
	|	И Правила.Активно
	|
	|УПОРЯДОЧИТЬ ПО
	|	Правила.Приоритет,
	|	Правила.Наименование";
	
	Правила = Запрос.Выполнить().Выгрузить();
	Правила.Колонки.Добавить("УсловияНазначенияПлатежа");
	
	Если Правила.Количество() = 0 Тогда
		Возврат Правила;
	КонецЕсли;
	
	Для Каждого Правило Из Правила Цикл
		Правило.УсловияНазначенияПлатежа = Новый Массив;
	КонецЦикла;
	
	ЗаполнитьУсловияНазначенияПлатежа(Правила);
	
	Возврат Правила;
	
КонецФункции

#КонецОбласти

#Область ПодборПравил

Функция ЭтоНоваяОперацияДляПравил(Операция, РаспознаннаяВыписка)
	
	РаспознаннаяОперация = РаспознаннаяВыписка.Операции.Найти(Операция.Идентификатор, "Идентификатор");
	Если РаспознаннаяОперация = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РаспознаннаяОперация.ПлатежноеПоручение)
		Или ЗначениеЗаполнено(РаспознаннаяОперация.Ссылка)
		Или РаспознаннаяОперация.ХозяйственнаяОперация = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Функция ЭтоХозяйственнаяОперацияОплатаПокупателя(ХозяйственнаяОперация)
	
	Если Не ХозяйственнаяОперация.Свойство("ВидОперацииДокумента")
		Или Не ХозяйственнаяОперация.Свойство("Контрагент")
		Или Не ХозяйственнаяОперация.Свойство("ДоговорКонтрагента") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат ХозяйственнаяОперация.ВидОперацииДокумента
		= Перечисления.ВидыОперацийПоступлениеДенежныхСредств.ОплатаПокупателя;
	
КонецФункции

Функция ПервоеПодходящееПравило(Правила, Выписка, РаспознаннаяВыписка, Операция, ХозяйственнаяОперация)
	
	Для Каждого Правило Из Правила Цикл
		Если ПравилоПодходит(Правило, Выписка, РаспознаннаяВыписка, Операция, ХозяйственнаяОперация) Тогда
			Возврат Правило;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

Функция ПравилоПодходит(Правило, Выписка, РаспознаннаяВыписка, Операция, ХозяйственнаяОперация)
	
	ВладелецСчета = РаспознаннаяВыписка.ВладелецСчета;
	
	Если ЗначениеЗаполнено(Правило.НаправлениеОперации)
		И Правило.НаправлениеОперации <> Перечисления.ВП_НаправленияОперацийВыписки.Любая Тогда
		Если Правило.НаправлениеОперации = Перечисления.ВП_НаправленияОперацийВыписки.Поступление
			И Операция.ПоступилоСписано <> "Поступило" Тогда
			Возврат Ложь;
		КонецЕсли;
		Если Правило.НаправлениеОперации = Перечисления.ВП_НаправленияОперацийВыписки.Списание
			И Операция.ПоступилоСписано <> "Списано" Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Правило.Организация)
		И Правило.Организация <> ВладелецСчета.Организация Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Правило.БанковскийСчетОрганизации)
		И Правило.БанковскийСчетОрганизации <> ВладелецСчета.БанковскийСчет Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ВидОперацииДокумента = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
		ХозяйственнаяОперация,
		"ВидОперацииДокумента",
		Перечисления.ВидыОперацийПоступлениеДенежныхСредств.ПустаяСсылка());
	Если ЗначениеЗаполнено(Правило.ВидОперацииДокумента)
		И Правило.ВидОперацииДокумента <> ВидОперацииДокумента Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Контрагент = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
		ХозяйственнаяОперация,
		"Контрагент",
		Справочники.Контрагенты.ПустаяСсылка());
	Если ЗначениеЗаполнено(Правило.Контрагент)
		И Правило.Контрагент <> Контрагент Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ИННПлательщика = ИННПлательщикаОперации(Операция);
	Если ЗначениеЗаполнено(Правило.ИННПлательщика)
		И СокрЛП(Правило.ИННПлательщика) <> ИННПлательщика Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если Не УсловияНазначенияПлатежаВыполнены(Правило.УсловияНазначенияПлатежа, Операция.НазначениеПлатежа) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Функция УсловияНазначенияПлатежаВыполнены(Условия, НазначениеПлатежа)
	
	Для Каждого Условие Из Условия Цикл
		
		Если Не ЗначениеЗаполнено(Условие.СтрокаПоиска) Тогда
			Продолжить;
		КонецЕсли;
		
		Текст = НазначениеПлатежа;
		СтрокаПоиска = Условие.СтрокаПоиска;
		Если Условие.БезУчетаРегистра Тогда
			Текст = НРег(Текст);
			СтрокаПоиска = НРег(СтрокаПоиска);
		КонецЕсли;
		
		ЕстьВхождение = СтрНайти(Текст, СтрокаПоиска) > 0;
		
		Если Условие.ВидУсловия = Перечисления.ВП_ВидыУсловийНазначенияПлатежа.Содержит
			И Не ЕстьВхождение Тогда
			Возврат Ложь;
		ИначеЕсли Условие.ВидУсловия = Перечисления.ВП_ВидыУсловийНазначенияПлатежа.НеСодержит
			И ЕстьВхождение Тогда
			Возврат Ложь;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

#КонецОбласти

#Область ДействияПравил

Функция ПрименитьДействияПравила(Правило, Операция, ХозяйственнаяОперация)
	
	КоличествоЗаполненныхРеквизитов = 0;
	РежимЗаполнения = Правило.РежимЗаполненияСчета;
	
	Если Операция.ПоступилоСписано = "Поступило" Тогда
		Если УстановитьСвойствоХозяйственнойОперации(
				ХозяйственнаяОперация,
				"ВидОперацииДокумента",
				Правило.ВидОперацииПоступление,
				РежимЗаполнения) Тогда
			КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
		КонецЕсли;
	ИначеЕсли Операция.ПоступилоСписано = "Списано" Тогда
		Если УстановитьСвойствоХозяйственнойОперации(
				ХозяйственнаяОперация,
				"ВидОперацииДокумента",
				Правило.ВидОперацииСписание,
				РежимЗаполнения) Тогда
			КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
		КонецЕсли;
	КонецЕсли;
	
	Если УстановитьСвойствоХозяйственнойОперации(
			ХозяйственнаяОперация,
			"Контрагент",
			Правило.ЗаполняемыйКонтрагент,
			РежимЗаполнения) Тогда
		КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
	КонецЕсли;
	
	Если УстановитьСвойствоХозяйственнойОперации(
			ХозяйственнаяОперация,
			"ДоговорКонтрагента",
			Правило.ЗаполняемыйДоговорКонтрагента,
			РежимЗаполнения) Тогда
		КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
	КонецЕсли;
	
	Если УстановитьСвойствоХозяйственнойОперации(
			ХозяйственнаяОперация,
			"БанковскийСчетКонтрагента",
			Правило.ЗаполняемыйБанковскийСчетКонтрагента,
			РежимЗаполнения) Тогда
		КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
	КонецЕсли;
	
	Если УстановитьСвойствоХозяйственнойОперации(
			ХозяйственнаяОперация,
			"СтатьяДвиженияДенежныхСредств",
			Правило.СтатьяДвиженияДенежныхСредств,
			РежимЗаполнения) Тогда
		КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
	КонецЕсли;
	
	Если УстановитьСвойствоХозяйственнойОперации(
			ХозяйственнаяОперация,
			"СчетДт",
			Правило.СчетДт,
			РежимЗаполнения) Тогда
		КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
		Если Операция.ПоступилоСписано = "Списано" Тогда
			ХозяйственнаяОперация.Вставить("СчетУчетаРасчетовСКонтрагентом", Правило.СчетДт);
		КонецЕсли;
	КонецЕсли;
	
	Если УстановитьСвойствоХозяйственнойОперации(
			ХозяйственнаяОперация,
			"СчетКт",
			Правило.СчетКт,
			РежимЗаполнения) Тогда
		КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
		Если Операция.ПоступилоСписано = "Поступило" Тогда
			ХозяйственнаяОперация.Вставить("СчетУчетаРасчетовСКонтрагентом", Правило.СчетКт);
		КонецЕсли;
	КонецЕсли;
	
	Если УстановитьСвойствоХозяйственнойОперации(
			ХозяйственнаяОперация,
			"ПодразделениеДт",
			Правило.ПодразделениеДт,
			РежимЗаполнения) Тогда
		КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
	КонецЕсли;
	
	Если УстановитьСвойствоХозяйственнойОперации(
			ХозяйственнаяОперация,
			"ПодразделениеКт",
			Правило.ПодразделениеКт,
			РежимЗаполнения) Тогда
		КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
	КонецЕсли;
	
	Если УстановитьСтатьюПрочихДоходовИРасходов(
			ХозяйственнаяОперация,
			Операция,
			Правило.СтатьяПрочихДоходовИРасходов,
			РежимЗаполнения) Тогда
		КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
	КонецЕсли;
	
	Возврат КоличествоЗаполненныхРеквизитов;
	
КонецФункции

Функция ПрименитьДействияПравилаКДокументу(Правило, Операция, ДокументОбъект)
	
	КоличествоЗаполненныхРеквизитов = 0;
	РежимЗаполнения = Правило.РежимЗаполненияСчета;
	
	Если Операция.ПоступилоСписано = "Поступило" Тогда
		Если ЗаполнитьРеквизитДокументаПоПравилу(ДокументОбъект, "ВидОперации", Правило.ВидОперацииПоступление, РежимЗаполнения) Тогда
			КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
		КонецЕсли;
	ИначеЕсли Операция.ПоступилоСписано = "Списано" Тогда
		Если ЗаполнитьРеквизитДокументаПоПравилу(ДокументОбъект, "ВидОперации", Правило.ВидОперацииСписание, РежимЗаполнения) Тогда
			КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗаполнитьРеквизитДокументаПоПравилу(ДокументОбъект, "Контрагент", Правило.ЗаполняемыйКонтрагент, РежимЗаполнения) Тогда
		КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
	КонецЕсли;
	
	Если ЗаполнитьРеквизитДокументаПоПравилу(ДокументОбъект, "ДоговорКонтрагента", Правило.ЗаполняемыйДоговорКонтрагента, РежимЗаполнения) Тогда
		КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
	КонецЕсли;
	
	Если ЗаполнитьРеквизитДокументаПоПравилу(ДокументОбъект, "СчетКонтрагента", Правило.ЗаполняемыйБанковскийСчетКонтрагента, РежимЗаполнения) Тогда
		КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
	КонецЕсли;
	
	Если ЗаполнитьРеквизитДокументаПоПравилу(ДокументОбъект, "СтатьяДвиженияДенежныхСредств", Правило.СтатьяДвиженияДенежныхСредств, РежимЗаполнения) Тогда
		КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
	КонецЕсли;
	
	Если ЗаполнитьРеквизитДокументаПоПравилу(ДокументОбъект, "СчетУчетаРасчетовСКонтрагентом", ?(Операция.ПоступилоСписано = "Поступило", Правило.СчетКт, Правило.СчетДт), РежимЗаполнения) Тогда
		КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
	КонецЕсли;
	
	Если ЗаполнитьРеквизитДокументаПоПравилу(ДокументОбъект, "СчетДт", Правило.СчетДт, РежимЗаполнения) Тогда
		КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
	КонецЕсли;
	
	Если ЗаполнитьРеквизитДокументаПоПравилу(ДокументОбъект, "СчетКт", Правило.СчетКт, РежимЗаполнения) Тогда
		КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
	КонецЕсли;
	
	Если ЗаполнитьРеквизитДокументаПоПравилу(ДокументОбъект, "ПодразделениеДт", Правило.ПодразделениеДт, РежимЗаполнения) Тогда
		КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
	КонецЕсли;
	
	Если ЗаполнитьРеквизитДокументаПоПравилу(ДокументОбъект, "ПодразделениеКт", Правило.ПодразделениеКт, РежимЗаполнения) Тогда
		КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
	КонецЕсли;
	
	Если ЗаполнитьСтатьюПрочихДоходовИРасходовВДокументе(ДокументОбъект, Операция, Правило.СтатьяПрочихДоходовИРасходов, РежимЗаполнения) Тогда
		КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
	КонецЕсли;
	
	КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов
		+ ЗаполнитьРасшифровкуПлатежаПоПравилу(ДокументОбъект, Операция, Правило, РежимЗаполнения);
	
	Возврат КоличествоЗаполненныхРеквизитов;
	
КонецФункции

Функция УстановитьСвойствоХозяйственнойОперации(ХозяйственнаяОперация, ИмяСвойства, Значение, РежимЗаполнения)
	
	Если Не ЗначениеЗаполнено(Значение) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	СуществующееЗначение = Неопределено;
	Если РежимЗаполнения = Перечисления.ВП_РежимыЗаполненияСчетаНаОплату.ТолькоЕслиПусто
		И ХозяйственнаяОперация.Свойство(ИмяСвойства, СуществующееЗначение)
		И ЗначениеЗаполнено(СуществующееЗначение) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ХозяйственнаяОперация.Вставить(ИмяСвойства, Значение);
	Возврат Истина;
	
КонецФункции

Функция УстановитьСтатьюПрочихДоходовИРасходов(ХозяйственнаяОперация, Операция, Статья, РежимЗаполнения)
	
	Если Не ЗначениеЗаполнено(Статья) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ИмяСубконто = ?(Операция.ПоступилоСписано = "Поступило", "СубконтоКт", "СубконтоДт");
	ВидСубконто = ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ПрочиеДоходыИРасходы;
	
	Субконто = Неопределено;
	Если ХозяйственнаяОперация.Свойство(ИмяСубконто, Субконто)
		И ТипЗнч(Субконто) = Тип("Соответствие")
		И РежимЗаполнения = Перечисления.ВП_РежимыЗаполненияСчетаНаОплату.ТолькоЕслиПусто
		И ЗначениеЗаполнено(Субконто[ВидСубконто]) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ТипЗнч(Субконто) <> Тип("Соответствие") Тогда
		Субконто = Новый Соответствие;
	КонецЕсли;
	
	Субконто.Вставить(ВидСубконто, Статья);
	ХозяйственнаяОперация.Вставить(ИмяСубконто, Субконто);
	
	Возврат Истина;
	
КонецФункции

Функция ЗаполнитьРеквизитДокументаПоПравилу(ДокументОбъект, ИмяРеквизита, Значение, РежимЗаполнения)
	
	Если Не ЗначениеЗаполнено(Значение) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если Не ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДокументОбъект, ИмяРеквизита) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если РежимЗаполнения = Перечисления.ВП_РежимыЗаполненияСчетаНаОплату.ТолькоЕслиПусто
		И ЗначениеЗаполнено(ДокументОбъект[ИмяРеквизита]) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ДокументОбъект[ИмяРеквизита] = Значение;
	Возврат Истина;
	
КонецФункции

Функция ЗаполнитьСтатьюПрочихДоходовИРасходовВДокументе(ДокументОбъект, Операция, Статья, РежимЗаполнения)
	
	Если Не ЗначениеЗаполнено(Статья) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	КандидатыРеквизитов = Новый Массив;
	КандидатыРеквизитов.Добавить("ПрочиеДоходыИРасходы");
	КандидатыРеквизитов.Добавить("СтатьяДоходов");
	КандидатыРеквизитов.Добавить("СтатьяРасходов");
	Если Операция.ПоступилоСписано = "Поступило" Тогда
		КандидатыРеквизитов.Добавить("СубконтоКт1");
	Иначе
		КандидатыРеквизитов.Добавить("СубконтоДт1");
	КонецЕсли;
	
	Для Каждого ИмяРеквизита Из КандидатыРеквизитов Цикл
		Если ЗаполнитьРеквизитДокументаПоПравилу(ДокументОбъект, ИмяРеквизита, Статья, РежимЗаполнения) Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

Функция ЗаполнитьРасшифровкуПлатежаПоПравилу(ДокументОбъект, Операция, Правило, РежимЗаполнения)
	
	Если Не ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДокументОбъект, "РасшифровкаПлатежа") Тогда
		Возврат 0;
	КонецЕсли;
	
	КоличествоЗаполненныхРеквизитов = 0;
	СчетУчета = ?(Операция.ПоступилоСписано = "Поступило", Правило.СчетКт, Правило.СчетДт);
	
	Для Каждого СтрокаРасшифровки Из ДокументОбъект.РасшифровкаПлатежа Цикл
		
		Если ЗаполнитьРеквизитДокументаПоПравилу(
				СтрокаРасшифровки,
				"СтатьяДвиженияДенежныхСредств",
				Правило.СтатьяДвиженияДенежныхСредств,
				РежимЗаполнения) Тогда
			КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
		КонецЕсли;
		
		Если ЗаполнитьРеквизитДокументаПоПравилу(
				СтрокаРасшифровки,
				"ДоговорКонтрагента",
				Правило.ЗаполняемыйДоговорКонтрагента,
				РежимЗаполнения) Тогда
			КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
		КонецЕсли;
		
		Если ЗаполнитьРеквизитДокументаПоПравилу(
				СтрокаРасшифровки,
				"СчетУчетаРасчетовСКонтрагентом",
				СчетУчета,
				РежимЗаполнения) Тогда
			КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
		КонецЕсли;
		
		Если Правило.РежимПоискаСчета = Перечисления.ВП_РежимыПоискаСчетаНаОплату.КонкретныйСчет Тогда
			Если ЗаполнитьРеквизитДокументаПоПравилу(
					СтрокаРасшифровки,
					"СчетНаОплату",
					Правило.СчетНаОплатуПокупателю,
					РежимЗаполнения) Тогда
				КоличествоЗаполненныхРеквизитов = КоличествоЗаполненныхРеквизитов + 1;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат КоличествоЗаполненныхРеквизитов;
	
КонецФункции

Функция ПравилоЗаполняетСчетНаОплату(Правило)
	
	Если Не ЗначениеЗаполнено(Правило.РежимПоискаСчета) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Правило.РежимПоискаСчета
		<> Перечисления.ВП_РежимыПоискаСчетаНаОплату.НеЗаполнять;
	
КонецФункции

#КонецОбласти

#Область ПоискСчета

Функция СчетНаОплатуПоПравилу(Правило, Выписка, РаспознаннаяВыписка, Операция, ХозяйственнаяОперация)
	
	Результат = Новый Структура;
	Результат.Вставить("Успешно", Ложь);
	Результат.Вставить("Счет", Документы.СчетНаОплатуПокупателю.ПустаяСсылка());
	Результат.Вставить("Сообщение", "");
	
	Если Правило.РежимПоискаСчета = Перечисления.ВП_РежимыПоискаСчетаНаОплату.КонкретныйСчет Тогда
		Возврат КонкретныйСчетНаОплату(Правило);
	КонецЕсли;
	
	Если Правило.РежимПоискаСчета = Перечисления.ВП_РежимыПоискаСчетаНаОплату.ПоНомеруВНазначении Тогда
		Возврат СчетНаОплатуПоНомеруВНазначении(Операция, РаспознаннаяВыписка, ХозяйственнаяОперация);
	КонецЕсли;
	
	Если Правило.РежимПоискаСчета = Перечисления.ВП_РежимыПоискаСчетаНаОплату.ПоКонтрагентуЕслиОдин Тогда
		Возврат СчетНаОплатуПоКонтрагентуЕслиОдин(Операция, РаспознаннаяВыписка, ХозяйственнаяОперация);
	КонецЕсли;
	
	Если Правило.РежимПоискаСчета = Перечисления.ВП_РежимыПоискаСчетаНаОплату.РаспределитьПоНесколькимСчетам Тогда
		Результат.Сообщение = "Распределение по нескольким счетам заложено в модель, но не реализовано в MVP.";
		Возврат Результат;
	КонецЕсли;
	
	Результат.Сообщение = "Неизвестный режим поиска счета.";
	Возврат Результат;
	
КонецФункции

Функция КонкретныйСчетНаОплату(Правило)
	
	Результат = Новый Структура;
	Результат.Вставить("Успешно", Ложь);
	Результат.Вставить("Счет", Документы.СчетНаОплатуПокупателю.ПустаяСсылка());
	Результат.Вставить("Сообщение", "");
	
	Если Не ЗначениеЗаполнено(Правило.СчетНаОплатуПокупателю) Тогда
		Результат.Сообщение = "В правиле не выбран счет на оплату покупателю.";
		Возврат Результат;
	КонецЕсли;
	
	Результат.Успешно = Истина;
	Результат.Счет = Правило.СчетНаОплатуПокупателю;
	Результат.Сообщение = "Использован счет, выбранный в правиле.";
	
	Возврат Результат;
	
КонецФункции

Функция СчетНаОплатуПоНомеруВНазначении(Операция, РаспознаннаяВыписка, ХозяйственнаяОперация)
	
	Результат = Новый Структура;
	Результат.Вставить("Успешно", Ложь);
	Результат.Вставить("Счет", Документы.СчетНаОплатуПокупателю.ПустаяСсылка());
	Результат.Вставить("Сообщение", "");
	
	Счета = НеоплаченныеСчетаПокупателя(Операция, РаспознаннаяВыписка, ХозяйственнаяОперация);
	Если Счета.Количество() = 0 Тогда
		Результат.Сообщение = "Не найдены неоплаченные счета покупателя.";
		Возврат Результат;
	КонецЕсли;
	
	НазначениеПлатежа = НРег(Операция.НазначениеПлатежа);
	НайденныеСчета = Новый ТаблицаЗначений;
	НайденныеСчета.Колонки.Добавить("Документ");
	НайденныеСчета.Колонки.Добавить("Оценка", Новый ОписаниеТипов("Число"));
	
	Для Каждого Счет Из Счета Цикл
		
		НомерНаПечать = НРег(СокрЛП(ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(Счет.Номер, Истина, Ложь)));
		Если Не ЗначениеЗаполнено(НомерНаПечать) Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрНайти(НазначениеПлатежа, НомерНаПечать) = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = НайденныеСчета.Добавить();
		НоваяСтрока.Документ = Счет.Документ;
		НоваяСтрока.Оценка = ОценкаСчета(Счет, Операция);
		
	КонецЦикла;
	
	Возврат ЕдинственныйЛучшийСчет(НайденныеСчета, "Счет найден по номеру в назначении платежа.");
	
КонецФункции

Функция СчетНаОплатуПоКонтрагентуЕслиОдин(Операция, РаспознаннаяВыписка, ХозяйственнаяОперация)
	
	Результат = Новый Структура;
	Результат.Вставить("Успешно", Ложь);
	Результат.Вставить("Счет", Документы.СчетНаОплатуПокупателю.ПустаяСсылка());
	Результат.Вставить("Сообщение", "");
	
	Счета = НеоплаченныеСчетаПокупателя(Операция, РаспознаннаяВыписка, ХозяйственнаяОперация);
	Если Счета.Количество() = 0 Тогда
		Результат.Сообщение = "Не найдены неоплаченные счета покупателя.";
		Возврат Результат;
	ИначеЕсли Счета.Количество() > 1 Тогда
		Результат.Сообщение = "Найдено несколько неоплаченных счетов покупателя; автоматический выбор не выполнен.";
		Возврат Результат;
	КонецЕсли;
	
	Результат.Успешно = Истина;
	Результат.Счет = Счета[0].Документ;
	Результат.Сообщение = "Найден единственный неоплаченный счет покупателя.";
	
	Возврат Результат;
	
КонецФункции

Функция НеоплаченныеСчетаПокупателя(Операция, РаспознаннаяВыписка, ХозяйственнаяОперация)
	
	Организация = РаспознаннаяВыписка.ВладелецСчета.Организация;
	Контрагент = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
		ХозяйственнаяОперация,
		"Контрагент",
		Справочники.Контрагенты.ПустаяСсылка());
	ДоговорКонтрагента = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
		ХозяйственнаяОперация,
		"ДоговорКонтрагента",
		Справочники.ДоговорыКонтрагентов.ПустаяСсылка());
	
	ДатаОперации = ?(ЗначениеЗаполнено(Операция.ДатаИсполнения), Операция.ДатаИсполнения, Операция.ДатаДокумента);
	Если Не ЗначениеЗаполнено(ДатаОперации) Тогда
		ДатаОперации = ТекущаяДата();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Запрос.УстановитьПараметр("ДоговорКонтрагента", ДоговорКонтрагента);
	Запрос.УстановитьПараметр("УчитыватьДоговор", ЗначениеЗаполнено(ДоговорКонтрагента));
	Запрос.УстановитьПараметр("ПериодАктуальности", ДобавитьМесяц(НачалоДня(ДатаОперации), -12));
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Счет.Ссылка КАК Документ,
	|	Счет.Дата КАК Дата,
	|	Счет.Номер КАК Номер,
	|	Счет.Контрагент КАК Контрагент,
	|	Счет.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	МАКСИМУМ(Счет.СуммаДокумента) КАК Сумма,
	|	СУММА(ЕСТЬNULL(ОплатаСчетов.Сумма, 0)) КАК УжеОплаченнаяСумма,
	|	МАКСИМУМ(Счет.СуммаДокумента) - СУММА(ЕСТЬNULL(ОплатаСчетов.Сумма, 0)) КАК НеоплаченнаяСумма,
	|	Счет.Проведен КАК Проведен
	|ИЗ
	|	Документ.СчетНаОплатуПокупателю КАК Счет
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОплатаСчетов КАК ОплатаСчетов
	|		ПО Счет.Организация = ОплатаСчетов.Организация
	|			И Счет.Ссылка = ОплатаСчетов.СчетНаОплату
	|ГДЕ
	|	НЕ Счет.ПометкаУдаления
	|	И Счет.Организация = &Организация
	|	И Счет.Контрагент = &Контрагент
	|	И Счет.Дата >= &ПериодАктуальности
	|	И (&УчитыватьДоговор = ЛОЖЬ ИЛИ Счет.ДоговорКонтрагента = &ДоговорКонтрагента)
	|
	|СГРУППИРОВАТЬ ПО
	|	Счет.Ссылка,
	|	Счет.Дата,
	|	Счет.Номер,
	|	Счет.Контрагент,
	|	Счет.ДоговорКонтрагента,
	|	Счет.Проведен
	|
	|ИМЕЮЩИЕ
	|	МАКСИМУМ(Счет.СуммаДокумента) > СУММА(ЕСТЬNULL(ОплатаСчетов.Сумма, 0))
	|
	|УПОРЯДОЧИТЬ ПО
	|	Счет.Дата,
	|	Счет.Номер";
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Функция ОценкаСчета(Счет, Операция)
	
	Оценка = 0;
	
	Если Счет.Проведен Тогда
		Оценка = Оценка + 4;
	КонецЕсли;
	
	Если Счет.НеоплаченнаяСумма = Операция.Сумма Тогда
		Оценка = Оценка + 8;
	ИначеЕсли Счет.НеоплаченнаяСумма < Операция.Сумма Тогда
		Оценка = Оценка + 2;
	КонецЕсли;
	
	Если Год(Счет.Дата) = Год(Операция.ДатаДокумента) Тогда
		Оценка = Оценка + 1;
	КонецЕсли;
	
	Возврат Оценка;
	
КонецФункции

Функция ЕдинственныйЛучшийСчет(НайденныеСчета, СообщениеУспеха)
	
	Результат = Новый Структура;
	Результат.Вставить("Успешно", Ложь);
	Результат.Вставить("Счет", Документы.СчетНаОплатуПокупателю.ПустаяСсылка());
	Результат.Вставить("Сообщение", "");
	
	Если НайденныеСчета.Количество() = 0 Тогда
		Результат.Сообщение = "Не найден счет на оплату покупателю.";
		Возврат Результат;
	КонецЕсли;
	
	НайденныеСчета.Сортировать("Оценка Убыв");
	ЛучшаяОценка = НайденныеСчета[0].Оценка;
	
	КоличествоЛучших = 0;
	Для Каждого Счет Из НайденныеСчета Цикл
		Если Счет.Оценка = ЛучшаяОценка Тогда
			КоличествоЛучших = КоличествоЛучших + 1;
		КонецЕсли;
	КонецЦикла;
	
	Если КоличествоЛучших <> 1 Тогда
		Результат.Сообщение = "Найдено несколько счетов с одинаковой оценкой; автоматический выбор не выполнен.";
		Возврат Результат;
	КонецЕсли;
	
	Результат.Успешно = Истина;
	Результат.Счет = НайденныеСчета[0].Документ;
	Результат.Сообщение = СообщениеУспеха;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗаполнитьУсловияНазначенияПлатежа(Правила)
	
	СсылкиПравил = Новый Массив;
	Для Каждого Правило Из Правила Цикл
		СсылкиПравил.Добавить(Правило.Ссылка);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СсылкиПравил", СсылкиПравил);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Условия.Ссылка КАК Правило,
	|	Условия.НомерСтроки КАК НомерСтроки,
	|	Условия.ВидУсловия КАК ВидУсловия,
	|	Условия.СтрокаПоиска КАК СтрокаПоиска,
	|	Условия.БезУчетаРегистра КАК БезУчетаРегистра
	|ИЗ
	|	Справочник.ВП_ПравилаОбработкиБанковскойВыписки.УсловияНазначенияПлатежа КАК Условия
	|ГДЕ
	|	Условия.Ссылка В (&СсылкиПравил)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Условия.Ссылка,
	|	Условия.НомерСтроки";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		СтрокиПравила = Правила.НайтиСтроки(Новый Структура("Ссылка", Выборка.Правило));
		Если СтрокиПравила.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Условие = Новый Структура;
		Условие.Вставить("ВидУсловия", Выборка.ВидУсловия);
		Условие.Вставить("СтрокаПоиска", Выборка.СтрокаПоиска);
		Условие.Вставить("БезУчетаРегистра", Выборка.БезУчетаРегистра);
		СтрокиПравила[0].УсловияНазначенияПлатежа.Добавить(Условие);
		
	КонецЦикла;
	
КонецПроцедуры

Функция ИННПлательщикаОперации(Операция)
	
	Результат = "";
	
	Если Не ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Операция, "ПлательщикРеквизиты") Тогда
		Возврат Результат;
	КонецЕсли;
	
	Реквизиты = Операция.ПлательщикРеквизиты;
	Если ТипЗнч(Реквизиты) = Тип("Структура") Тогда
		Результат = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Реквизиты, "ИНН", "");
	КонецЕсли;
	
	Возврат СокрЛП(Результат);
	
КонецФункции

Процедура ОчиститьСохраненноеАвтозаполнение(ХозяйственнаяОперация)
	
	Если ХозяйственнаяОперация.Свойство("ДокументОбъект") Тогда
		ХозяйственнаяОперация.Удалить("ДокументОбъект");
	КонецЕсли;
	
	Если ХозяйственнаяОперация.Свойство("ДанныеАвтозаполнения") Тогда
		ХозяйственнаяОперация.Удалить("ДанныеАвтозаполнения");
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаписатьЖурналПрименения(
	Правило,
	Выписка,
	РаспознаннаяВыписка,
	Операция,
	ХозяйственнаяОперация,
	СчетНаОплату,
	Результат,
	Сообщение)
	
	Попытка
		
		НаборЗаписей = РегистрыСведений.ВП_ЖурналПримененияПравилВыписки.СоздатьНаборЗаписей();
		Запись = НаборЗаписей.Добавить();
		Запись.Период = ТекущаяДата();
		
		Запись.Правило = Правило.Ссылка;
		Запись.ИдентификаторВыписки = Строка(Выписка.Идентификатор);
		Запись.ИдентификаторОперации = Строка(Операция.Идентификатор);
		
		Запись.Организация = РаспознаннаяВыписка.ВладелецСчета.Организация;
		Запись.БанковскийСчетОрганизации = РаспознаннаяВыписка.ВладелецСчета.БанковскийСчет;
		Запись.Контрагент = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
			ХозяйственнаяОперация,
			"Контрагент",
			Справочники.Контрагенты.ПустаяСсылка());
		Запись.ИННПлательщика = ИННПлательщикаОперации(Операция);
		Запись.НомерДокументаБанка = Операция.НомерДокумента;
		Запись.ДатаДокументаБанка = Операция.ДатаДокумента;
		Запись.Сумма = Операция.Сумма;
		Запись.РежимПоискаСчета = Правило.РежимПоискаСчета;
		Запись.РежимЗаполненияСчета = Правило.РежимЗаполненияСчета;
		Запись.СчетНаОплатуПокупателю = СчетНаОплату;
		Запись.Результат = Лев(Результат, 80);
		Запись.Сообщение = Лев(Сообщение, 500);
		
		НаборЗаписей.Записать();
		
	Исключение
		// Ошибка протоколирования не должна отменять загрузку выписки.
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти
